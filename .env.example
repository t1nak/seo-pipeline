# Anthropic API Key für Brief Generation (src/brief.py).
# Pflicht im Default Modus. Im --dry-run Modus optional (Stubs werden geschrieben).
# Holen unter https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# DataForSEO Credentials für Live Keyword Daten (src/enrich.py --provider dataforseo).
# Optional. Wenn nicht gesetzt, läuft enrich mit deterministischer Heuristik.
# Holen unter https://app.dataforseo.com/login
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
