# =====================================================================
# zvoove SEO Pipeline · Environment configuration
# =====================================================================
#
# Two kinds of variables:
#
#   Secrets         API keys and provider credentials. Pflicht je nach
#                   Provider, sonst leer. Niemals committen.
#
#   Pipeline-Vars   Mit Prefix PIPELINE_*. Optional, alle haben sichere
#                   Defaults in src/config.py. Hier nur überschreiben,
#                   wenn nötig.
#
# Precedence: CLI flag > shell env > .env > src/config.py default.
# =====================================================================

# ----- Secrets -----------------------------------------------------------

# Anthropic API Key für Brief Generation (src/brief.py --provider api)
# Holen unter https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API Key für Brief Generation (src/brief.py --provider openai)
# Holen unter https://platform.openai.com/api-keys
OPENAI_API_KEY=

# DataForSEO Credentials für Live Keyword Daten (src/enrich.py --provider dataforseo)
# Holen unter https://app.dataforseo.com/login
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=


# ----- Pipeline configuration (alle optional) ---------------------------

# Discover-Schritt
# PIPELINE_DISCOVER_SOURCE=manual
# PIPELINE_DISCOVER_MAX_KEYWORDS=500

# Enrich-Schritt
# PIPELINE_ENRICH_PROVIDER=estimate

# Cluster-Schritt: Embeddings
# PIPELINE_CLUSTER_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Cluster-Schritt: UMAP
# PIPELINE_CLUSTER_UMAP_NEIGHBORS=15
# PIPELINE_CLUSTER_UMAP_RANDOM_STATE=42
# PIPELINE_CLUSTER_UMAP_METRIC=cosine

# Cluster-Schritt: HDBSCAN
# PIPELINE_CLUSTER_HDBSCAN_MCS=15
# PIPELINE_CLUSTER_HDBSCAN_MS=5
# PIPELINE_CLUSTER_HDBSCAN_METHOD=eom
# PIPELINE_CLUSTER_HDBSCAN_METRIC=euclidean

# Brief-Schritt
# PIPELINE_BRIEF_PROVIDER=api
# PIPELINE_BRIEF_MODEL=
# PIPELINE_BRIEF_MAX_TOKENS=4096
