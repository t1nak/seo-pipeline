# Database — shared with the eraluma Django app, but this pipeline writes only to the `seo_pipeline` schema.
DATABASE_URL=postgresql+psycopg2://user:password@host:5432/ceraluna

# Google Search Console service account — path to a JSON key file kept out of git.
# The service account must have access to both GSC properties:
#   sc-domain:capetowndata.com
#   sc-domain:es-capetown.com
GSC_SERVICE_ACCOUNT_JSON_PATH=./credentials/gsc-service-account.json

# Optional: override default pacing / concurrency.
SITEMAP_CONCURRENCY=5
SITEMAP_REQUESTS_PER_SECOND=1.0
